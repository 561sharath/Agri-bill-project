# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
# Local:  mongodb://127.0.0.1:27017/agribill
# Atlas:  mongodb+srv://<user>:<pass>@cluster0.mongodb.net/agribill
MONGO_URI=mongodb://127.0.0.1:27017/agribill

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here

# ─── Shop Details ─────────────────────────────────────────────────────────────
SHOP_NAME=Basaveshwara Trading Company

# UPI ID used in credit reminder payment link (e.g. Google Pay / PhonePe / Paytm)
# Format: upi://pay?pa=UPI_ID&pn=SHOP_NAME&am=AMOUNT&cu=INR
UPI_ID=yourname@ybl

# ─── WhatsApp (ChatMitra) ─────────────────────────────────────────────────────
# Get your token from https://app.chatmitra.com → Developer → API Token
CHATMITRA_API_TOKEN=your_bearer_token_here

# Raw message endpoint (default shown below – change only if ChatMitra updates it)
# CHATMITRA_API_URL=https://backend.chatmitra.com/developer/api/send_message

# Template message endpoint (used for credit_payment_reminder__2026 template)
# CHATMITRA_TEMPLATE_API_URL=https://backend.chatmitra.com/developer/api/send_template

# ─── Public URL for WhatsApp PDF ─────────────────────────────────────────────
# WhatsApp rejects http:// and localhost — must be public HTTPS (e.g. ngrok).
# Run: ngrok http 5002  →  copy the https URL here (no trailing slash).
# See backend/docs/NGROK-WHATSAPP.md
# PUBLIC_APP_URL=https://xxxx.ngrok-free.app
