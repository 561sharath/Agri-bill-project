# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
# Local MongoDB example: mongodb://127.0.0.1:27017/agribill
# MongoDB Atlas example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/agribill?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/agribill

# Authentication Settings
JWT_SECRET=your_super_secret_jwt_key_here
